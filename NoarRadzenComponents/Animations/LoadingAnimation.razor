@if (Visible)
{
	<div class=@Class>
		<RadzenImage Path="@LoadingIconPath" Style=@($"width:{Width} {Style}") />
		<RadzenText TextStyle="TextStyle.Body2" Text="@Text" />
	</div>
}
@code {
	private static readonly string LoadingIconPath = "_content/NoarRadzenComponents/Loading_icon.gif";

	[Parameter] public bool Visible { get; set; } = false;
	[Parameter] public string Width { get; set; } = "20px";
	[Parameter] public string Class { get; set; } = "d-flex justify-content-center";
	[Parameter] public string Style { get; set; } = "";
	[Parameter] public string Text { get; set; } = "Loading ...";

}
