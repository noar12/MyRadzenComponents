<RadzenColumn>
    <RadzenText TextStyle="TextStyle.Overline" Text="@Label" />
    @if (Bold)
    {
        <RadzenText TextStyle="TextStyle.Body1"><b>@Value.ToString(@Format)</b></RadzenText>
    }
    else
    {
        <RadzenText TextStyle="TextStyle.Body1">@Value.ToString(@Format)</RadzenText>
    }
</RadzenColumn>
@code {
    [Parameter]
    public string Label { get; set; } = "";
    [Parameter]
    public DateTime Value { get; set; }
    [Parameter]
    public bool Bold { get; set; } = true;
    [Parameter]
    public string Format { get; set; } = "yyyy-MM-dd HH:mm";
}
