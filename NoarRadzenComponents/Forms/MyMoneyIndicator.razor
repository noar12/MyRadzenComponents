<RadzenColumn>
    <RadzenText TextStyle="TextStyle.Overline" Text="@($"{Label} {Symbol}")" />
    @if (Bold)
    {
        <RadzenText TextStyle="TextStyle.Body1"><b>@Value.ToString(@Format)</b></RadzenText>
    }
    else
    {
        <RadzenText TextStyle="TextStyle.Body1">@Value.ToString(@Format)</RadzenText>
    }
</RadzenColumn>
@code {
    [Parameter]
    public string Label { get; set; } = "";
    [Parameter]
    public decimal Value { get; set; }
    [Parameter]
    public string Symbol {get; set;} = "";
    [Parameter]
    public bool Bold { get; set; } = true;
    [Parameter]
    public string Format { get; set; } = "F2";
}
